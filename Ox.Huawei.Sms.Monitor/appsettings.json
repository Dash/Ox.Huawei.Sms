{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.Hosting.Lifetime": "Information"
		}
	},
	"Device": {
		"BaseAddress": "http://192.168.8.1/api/"
	},
	"Dispatchers": {
		"SmtpDispatcher": {
			"Host": "localhost",
			"ToAddress": "root@localhost"
		},
		"MqttDispatcher": {
			"Host": "localhost",
			"Port": 1883,
			"TopicName": "sms/received",
			"Username": "",
			"Password": ""
		}
	},
	"Monitors": {
		"SmsMonitor": {
			"PollInterval": 5
		},
		"DeviceMonitor": {
			"PollInterval": 60
		},
		"MqttMonitor": {
			"Host": "localhost",
			"Port": 1883,
			"TopicName": "sms/send",
			"Username": "",
			"Password": ""
		}
	}
}
